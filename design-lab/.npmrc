# @duetto scoped packages come from Artifactory; everything else uses npmjs
@duetto:registry=https://duetto.jfrog.io/duetto/api/npm/duetto-js
//duetto.jfrog.io/duetto/api/npm/:_authToken=${artifactory_npm_auth_token}
# MUI v4 declares peer deps for @types/react ^16 || ^17; project uses ^18.
# legacy-peer-deps tells npm to use the npm 6 algorithm so the conflict doesn't hard-fail.
legacy-peer-deps=true
